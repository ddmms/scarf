\def\bottomrule{}
\def\midrule{}
\setbeamerfont{itemize/enumerate subbody}{size=\large}
\setbeamerfont{itemize/enumerate subsubbody}{size=\normalsize}
\setbeamerfont{normal text}{size=\Large}
\setbeamerfont{itemize/enumerate body}{size=\Large}

% Force \Large for all content including paragraphs and ensure centering
\addtobeamertemplate{background canvas}{}{\Large\centering}
\addtobeamertemplate{itemize/enumerate body begin}{}{\Large}
\addtobeamertemplate{itemize/enumerate subbody begin}{}{\large}

\makeatletter
\setbeamercolor{structure}{fg=myblue, bg=myorange}
\setbeamercolor{separation line}{bg=myorange}
\setbeamercolor{normal text}{fg=myblue, bg=myyellow}
\setbeamercolor{alerted text}{fg=red}
\setbeamercolor{example text}{fg=green!50!black}

\setbeamercolor{background canvas}{parent=normal text}
\setbeamercolor{background}{parent=background canvas, bg=myorange!10}
\setbeamercolor{palette primary}{fg=myblue} % changed this
\setbeamercolor{palette secondary}{use=structure,fg=myblue}
\setbeamercolor{palette tertiary}{use=structure,fg=myblue}
\setbeamercolor{palette quaternary}{fg=myblue}

\makeatother


